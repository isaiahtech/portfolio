# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit the real file.

# ─── Instagram Graph API ──────────────────────────────────────────────────────
# Requires a Business or Creator Instagram account linked to a Facebook Page.
# The old Instagram Basic Display API was deprecated December 2024.
#
# Setup steps:
# 1. Convert IG account to Creator or Business (Instagram app > Settings > Account)
# 2. Go to https://developers.facebook.com and create a Business app
# 3. Add the "Instagram Graph API" product to your app
# 4. Add your IG account as a tester and accept the invite in the Instagram app
# 5. Use Graph API Explorer to get a short-lived token, then exchange for long-lived:
#    GET https://graph.instagram.com/access_token
#      ?grant_type=ig_exchange_token
#      &client_id=YOUR_APP_ID
#      &client_secret=YOUR_APP_SECRET
#      &access_token=SHORT_LIVED_TOKEN
# 6. Get your numeric user ID:
#    GET https://graph.instagram.com/me?fields=id,username&access_token=YOUR_TOKEN
# 7. Tokens expire after ~60 days — refresh via:
#    GET https://graph.instagram.com/refresh_access_token
#      ?grant_type=ig_refresh_token&access_token=YOUR_CURRENT_TOKEN

INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_USER_ID=your_numeric_instagram_user_id_here

# Number of recent posts to show in the gallery (default: 12)
INSTAGRAM_POST_LIMIT=12
